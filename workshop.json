    "requirements": [
        {
            "name": "perl-modules",
            "type": "cpan",
            "cpan_info": {
                "packages": [
                    "PMQS/Compress-Raw-Zlib-2.105.tar.gz",
                    "PMQS/Compress-Raw-Lzma-2.103.tar.gz",
                    "PMQS/Compress-Raw-Bzip2-2.103.tar.gz",
                    "PMQS/IO-Compress-2.106.tar.gz",
                    "PMQS/IO-Compress-Lzma-2.103.tar.gz",
                    "JSON",
                    "JSON::XS",
                    "JSON::Validator"
                ]
            }
        },
        {
            "name": "distro-perl-tools",
            "type": "distro",
            "distro_info": {
                "packages": [
                    "perl-App-cpanminus"
                ]
            }
        },
        {
            "name": "toolbox-python-deps",
            "type": "python3",
            "python3_info": {
                "packages": [
                    "jsonschema"
                ]
            }
        }
