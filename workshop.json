{
    "workshop": {
        "schema": {
            "version": "2020.03.02"
        }
    },
    "userenvs": [
        {
            "name": "default",
            "requirements": []
        },
        {
            "name": "crucible-controller",
            "requirements": [
                "distro-perl-tools",
                "toolbox-python-deps"
            ]
        }
